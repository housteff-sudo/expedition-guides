---
import '../styles/global.css';
const { title, description = 'Expedition — Travel Books' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="cs">
<head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="description" content={description}><title>{title}</title>
<link rel="icon" href={`${base}icons/compass.svg`}>
</head>
<body id="top">
<header class="site-header"><div class="container nav">
<a class="brand" href={base}><img src={`${base}icons/compass.svg`} alt=""><span>EXPEDITION</span></a>
<nav class="nav-links"><a href={`${base}rome/`}>Rome</a><a href={`${base}book/`}>Book</a><a href={`${base}releases/v0-3-0/`}>Release</a></nav>
</div></header>
<slot />
<footer class="site-footer"><div class="container">EXPEDITION · Travel Books · Volume I: Rome</div></footer>
</body></html>
