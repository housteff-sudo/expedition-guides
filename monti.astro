---
import '../styles/global.css';
import '../styles/empire.css';
import { site } from '../data/site';

const { title, description = 'Expedition — Travel Books' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="cs">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#7a2e22" />
  <title>{title}</title>
  <link rel="icon" href={`${base}icons/compass.svg`} />
</head>
<body id="top">
  <header class="site-header">
    <div class="container nav">
      <a class="brand" href={base}>
        <img src={`${base}icons/compass.svg`} alt="" />
        <span>{site.name}</span>
      </a>
      <nav class="nav-links" aria-label="Hlavní navigace">
        <a href={`${base}rome/`}>Rome</a>
        <a href={`${base}rome/day-1/`}>Day I</a>
        <a href={`${base}book/`}>Book</a>
      </nav>
    </div>
  </header>
  <slot />
  <footer class="site-footer">
    <div class="container">{site.name} · {site.subtitle} · Volume I: Rome</div>
  </footer>
</body>
</html>
