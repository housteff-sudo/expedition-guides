
.day-hero{padding:72px 0 48px}
.day-quick-menu{display:grid;gap:12px}
.quick-stop{display:grid;grid-template-columns:76px 44px 1fr 30px;gap:14px;align-items:center;padding:18px 20px;border:1px solid var(--line);border-radius:20px;background:var(--surface);box-shadow:0 10px 28px rgba(48,31,21,.05);text-decoration:none;transition:.18s ease}
.quick-stop:hover{transform:translateX(5px);border-color:var(--rome)}
.quick-time{color:var(--rome);font-weight:900}.quick-icon{font-size:1.45rem;text-align:center}
.quick-title{font-family:Georgia,serif;font-size:1.25rem;font-weight:700}.quick-arrow{color:var(--rome);font-weight:900}
.place-page{padding:48px 0 86px}
.place-quick-card{max-width:1040px;margin:0 auto 34px;padding:clamp(24px,5vw,54px);border:1px solid var(--line);border-radius:34px;background:var(--surface);box-shadow:var(--shadow)}
.place-card-head{display:flex;justify-content:space-between;gap:24px;align-items:flex-start}
.place-card-head h1{font-size:clamp(2.8rem,7vw,5.8rem)}.place-symbol{display:inline-block;margin-right:.18em;color:var(--rome)}
.place-order{font-family:Georgia,serif;color:var(--paper-2);font-size:clamp(4rem,10vw,8rem);font-weight:700;line-height:.8}
.place-meta-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:30px 0}
.place-meta-grid div{padding:15px;border:1px solid var(--line);border-radius:17px;background:#fff}.place-meta-grid b,.place-meta-grid span{display:block}
.place-meta-grid b{color:var(--rome);font-size:.78rem;text-transform:uppercase;letter-spacing:.08em}.place-meta-grid span{margin-top:5px}
.mode-tabs{display:flex;gap:10px;margin:24px 0 20px;border-bottom:1px solid var(--line)}
.mode-tab{padding:11px 14px;text-decoration:none;color:var(--muted);font-weight:800}.mode-tab.active{color:var(--rome);border-bottom:3px solid var(--rome)}
.quick-read{max-width:820px;font-size:1.08rem}.place-actions{display:flex;flex-wrap:wrap;gap:10px;margin:26px 0}
.quick-columns,.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:28px}
.mini-panel{padding:22px;border:1px solid var(--line);border-radius:20px;background:#fbf5ec}.mini-panel ul,.fact-list{padding-left:20px}
.score-grid{display:grid;gap:11px}.score-row{display:flex;justify-content:space-between;gap:15px;align-items:center}
.score-dots{display:flex;gap:5px}.score-dots i{width:10px;height:10px;border-radius:50%;background:var(--line)}.score-dots i.active{background:var(--rome)}
.deep-dive{max-width:1040px}.deep-dive>h2{font-size:clamp(2.3rem,5vw,4rem)}
.deep-opening{font-family:Georgia,serif;font-size:1.35rem!important;line-height:1.55}
.lens-box{padding:22px;border-left:5px solid var(--bronze);border-radius:0 18px 18px 0;background:#f7eddd}
.next-stop-panel{display:flex;justify-content:space-between;align-items:center;gap:20px;margin-top:48px;padding-top:28px;border-top:1px solid var(--line)}
@media(max-width:760px){
  .quick-stop{grid-template-columns:62px 34px 1fr 18px;padding:15px 14px}
  .place-card-head{display:block}.place-order{display:none}
  .place-meta-grid{grid-template-columns:1fr 1fr}
  .quick-columns,.detail-grid{grid-template-columns:1fr}
  .next-stop-panel{align-items:flex-start;flex-direction:column}
}
